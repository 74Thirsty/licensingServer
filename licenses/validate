import fetch from 'node-fetch';

async function validateLicense(key, productId) {
  const res = await fetch('http://localhost:4000/licenses/validate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ key, productId }),
  });

  const data = await res.json();
  return data; // { valid, reason?, productId?, expiresAt? }
}

// Example usage in Gnoman 2.0 startup
(async () => {
  const userKey = process.env.GNOMAN_LICENSE_KEY; // or read from config/UI
  const result = await validateLicense(userKey, 'gnoman-2.0');

  if (!result.valid) {
    console.error('License invalid:', result.reason);
    process.exit(1);
  }

  console.log('License OK, expires at', new Date(result.expiresAt * 1000));
  // continue booting app...
})();
